{
  "rules": {
    "profile": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "joinCodes": {
      "$code": {
        ".read": true,
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)"
      }
    },

    "tweet": {
      ".read": "auth != null",
      ".indexOn": ["careRecipientId", "createdAt"],
      "$key": {
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid) && (!newData.exists() || newData.child('userId').val() === auth.uid)"
      }
    },

    "snippets": {
      "$recipientId": {
        ".read": "auth != null && (auth.uid === $recipientId || (root.child('profile').child(auth.uid).child('linkedRecipientId').val() === $recipientId))",
        ".indexOn": ["createdAt"],
        "$key": {
          ".write": "auth != null && (auth.uid === $recipientId || (root.child('profile').child(auth.uid).child('linkedRecipientId').val() === $recipientId))"
        }
      }
    },

    "sessions": {
      "$recipientId": {
        ".read": "auth != null && (auth.uid === $recipientId || (root.child('profile').child(auth.uid).child('linkedRecipientId').val() === $recipientId))",
        ".indexOn": ["startedAt"],
        "$key": {
          ".write": "auth != null && (auth.uid === $recipientId || (root.child('profile').child(auth.uid).child('linkedRecipientId').val() === $recipientId))"
        }
      }
    },

    "careSettings": {
      "$recipientId": {
        ".read": "auth != null && (auth.uid === $recipientId || (root.child('profile').child(auth.uid).child('linkedRecipientId').val() === $recipientId))",
        ".write": "auth != null && (auth.uid === $recipientId || (root.child('profile').child(auth.uid).child('linkedRecipientId').val() === $recipientId))"
      }
    }
  }
}
